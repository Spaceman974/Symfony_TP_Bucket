{% block form_row %}

    <div class="mb-4 w-full px-4">

        <div class="text-red-500 text-sm mb-1">
            {{ form_errors(form) }}
        </div>

        <div class="flex flex-col items-center w-full gap-2">

            {{ form_label(form) }}

            <div class="w-full">
                {% if form.vars.block_prefixes|filter(b => b == 'textarea')|length > 0 %}
                    {{ form_widget(form, {'attr': {'class': 'w-full p-4 border border-gray-300 rounded-md resize-none', 'rows': '4'}}) }}
                {% else %}
                    {{ form_widget(form, {'attr': {'class': 'w-full px-3 py-2 border border-gray-300 rounded-md h-10'}}) }}
                {% endif %}
            </div>

        </div>

    </div>

{% endblock %}
