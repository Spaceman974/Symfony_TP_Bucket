{% form_theme wishForm 'views/form/form-theme.html.twig' %}

<div class="backblanc flex flex-col justify-center items-center text-center py-5 w-full px-4">
    <h2 class="text-2xl font-bold">{% block formTitle %}{% endblock %}</h2>

    {{ form_start(wishForm, {'attr': {'class': 'w-full'}}) }}
    {{ form_widget(wishForm) }}
    <button
        class="bg-transparent hover:bg-blue-500 text-blue-700 font-semibold hover:text-white mx-5 py-2 px-4 border border-blue-500 hover:border-transparent rounded">
        {% block buttonLabel %}{% endblock %}
    </button>
    {{ form_end(wishForm) }}

</div>
