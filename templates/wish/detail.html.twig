{% extends 'base.html.twig' %}

{% block title %}
    {{ parent() }} | About
{% endblock %}

{% block main %}
    <section
        class="backblanc grid grid-cols-1 place-content-center text-center justify-items-center overflow-hidden w-full"
        style="height: 45vh">

        <div class="flex flex-col items-center w-full max-w-full px-4 overflow-y-auto h-full py-4 gap-6">

            {# Titre au-dessus #}
            <h2 class="text-3xl font-bold">Détails de la chose à faire N°{{ wish_id.id }}</h2>

            {# Ligne : image à gauche, contenu à droite #}
            <div class="flex flex-row gap-6 w-full items-start">

                {# Image à gauche #}
                <img class="imgWish flex-shrink-0" src="{{ asset('images/' ~ wish_id.image) }}"
                     alt="{{ wish_id.title }}">

                {# Contenu à droite #}
                <div class="flex flex-col gap-4 flex-1 text-left">

                    <div class="text-xl font-semibold">{{ wish_id.title }}</div>

                    <div>Créé le {{ wish_id.dateCreated | date('d/m/Y') }} par {{ wish_id.author }}</div>

                    <textarea class="w-full p-4 resize-none flex-shrink-0" rows="4">{{ wish_id.description }}</textarea>

                    <div class="flex gap-2">
                        <a href="{{ path('wish_update', {'id': wish_id.id}) }}">
                            <button type="button"
                                    class="bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded">
                                Modifier
                            </button>
                        </a>

                        <a href="{{ path('wish_delete', {'id': wish_id.id}) }}">
                            <button
                                onclick="return confirm('Warning, do you really want to delete your wish {{ wish_id.title }}?')"
                                type="button"
                                class="bg-red-500 hover:bg-red-700 text-white font-bold py-2 px-4 rounded">
                                Supprimer
                            </button>
                        </a>
                    </div>

                </div>
            </div>

        </div>

    </section>
{% endblock %}
